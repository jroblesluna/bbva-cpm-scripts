# ── Base de datos ─────────────────────────────────────────────────────────────
# SQLite para desarrollo local (no requiere instalar PostgreSQL)
DATABASE_URL=sqlite:///./alwaysprint.db

# PostgreSQL para producción:
# DATABASE_URL=postgresql://alwaysprint_admin:password@localhost:5432/alwaysprint

# ── Seguridad ─────────────────────────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── API ───────────────────────────────────────────────────────────────────────
API_V1_STR=/api/v1
PROJECT_NAME=AlwaysPrint Cloud Management

# ── Redis (opcional en desarrollo) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AWS SES — email transaccional ─────────────────────────────────────────────
# Con SES_ENABLED=false el enlace de reset se imprime en los logs (sin enviar email)
SES_ENABLED=false
SES_FROM_EMAIL=noreply@alwaysprint.apps.iol.pe
AWS_REGION=us-west-2
FRONTEND_URL=http://localhost:3000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG

# ── WebSocket ─────────────────────────────────────────────────────────────────
WS_PING_INTERVAL=30
WS_PING_TIMEOUT=60

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN=5
RATE_LIMIT_API=100
