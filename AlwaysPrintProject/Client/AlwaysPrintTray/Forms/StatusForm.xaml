<Window x:Class="AlwaysPrintTray.Forms.StatusForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AlwaysPrint — Estado del Sistema"
        Width="520" Height="620"
        MinWidth="480" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#1E1E2E"
        Foreground="#CDD6F4"
        DataContext="{Binding RelativeSource={RelativeSource Self}}">

    <Window.Resources>
        <!-- Estilo base para etiquetas de campo -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <!-- Estilo para valores de campo -->
        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Estilo para headers de sección -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#89B4FA"/>
            <Setter Property="Margin" Value="0,12,0,8"/>
        </Style>

        <!-- Estilo para botones de acción -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="72"/>
        </Style>

        <!-- Separador visual entre secciones -->
        <Style x:Key="SectionSeparator" TargetType="Separator">
            <Setter Property="Margin" Value="0,8,0,4"/>
            <Setter Property="Background" Value="#45475A"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Información General -->
            <RowDefinition Height="Auto"/>  <!-- Separador -->
            <RowDefinition Height="Auto"/>  <!-- Servicios -->
            <RowDefinition Height="Auto"/>  <!-- Separador -->
            <RowDefinition Height="*"/>     <!-- OnDemand Triggers -->
        </Grid.RowDefinitions>

        <!-- ═══ Sección: Información General ═══ -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Información General" Style="{StaticResource SectionHeader}"/>

            <!-- Estado del sistema -->
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Estado:" Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="1" Text="{Binding EstadoSistema}" Style="{StaticResource FieldValue}"/>
            </Grid>

            <!-- Versión -->
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Versión:" Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="1" Text="{Binding VersionApp}" Style="{StaticResource FieldValue}"/>
            </Grid>

            <!-- Cola activa gestionada -->
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Cola activa gestionada:" Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="1" Text="{Binding ColaActiva}" Style="{StaticResource FieldValue}" TextWrapping="Wrap"/>
            </Grid>

            <!-- Configuración activa -->
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Configuración:" Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="1" Text="{Binding ConfigActiva}" Style="{StaticResource FieldValue}"/>
            </Grid>
        </StackPanel>

        <!-- Separador -->
        <Separator Grid.Row="1" Style="{StaticResource SectionSeparator}"/>

        <!-- ═══ Sección: Estado de Servicios ═══ -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Estado de Servicios" Style="{StaticResource SectionHeader}"/>

            <ItemsControl ItemsSource="{Binding Servicios}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding DisplayName}" Style="{StaticResource FieldValue}"/>
                            <TextBlock Grid.Column="1" Text="{Binding State}" Style="{StaticResource FieldValue}"/>
                            <Button Grid.Column="2"
                                    Content="{Binding ActionLabel}"
                                    Style="{StaticResource ActionButton}"
                                    IsEnabled="{Binding IsActionEnabled}"
                                    HorizontalAlignment="Left"
                                    Click="ServiceAction_Click"
                                    Tag="{Binding}"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Separador -->
        <Separator Grid.Row="3" Style="{StaticResource SectionSeparator}"/>

        <!-- ═══ Sección: On Demand Triggers ═══ -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="On Demand Triggers" Style="{StaticResource SectionHeader}"/>

            <!-- Mensaje cuando no hay triggers -->
            <TextBlock x:Name="NoTriggersMessage"
                       Text="No hay acciones disponibles."
                       Style="{StaticResource FieldValue}"
                       Foreground="#A6ADC8"
                       FontStyle="Italic"
                       Visibility="Collapsed"
                       Margin="0,4"/>

            <ItemsControl x:Name="TriggersListControl" ItemsSource="{Binding TriggersOnDemand}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Label}" Style="{StaticResource FieldValue}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="Ejecutar"
                                    Style="{StaticResource ActionButton}"
                                    IsEnabled="{Binding IsActionEnabled}"
                                    Click="TriggerExecute_Click"
                                    Tag="{Binding}"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</Window>
