<Window x:Class="AlwaysPrintTray.Forms.StatusForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AlwaysPrint — Estado del Sistema"
        Width="480" Height="540"
        MinWidth="420" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F5F5F5"
        Foreground="#1E1E1E"
        DataContext="{Binding RelativeSource={RelativeSource Self}}">

    <Window.Resources>
        <!-- Estilo base para etiquetas de campo -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <!-- Estilo para valores de campo -->
        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#1E1E1E"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Estilo para headers de sección -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#0066CC"/>
            <Setter Property="Margin" Value="0,10,0,6"/>
        </Style>

        <!-- Estilo para botones de acción -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="68"/>
        </Style>

        <!-- Estilo para botón de ícono pequeño (reiniciar/iniciar servicio) -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI Symbol"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="200"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
        </Style>

        <!-- Separador visual entre secciones -->
        <Style x:Key="SectionSeparator" TargetType="Separator">
            <Setter Property="Margin" Value="0,6,0,2"/>
            <Setter Property="Background" Value="#DDDDDD"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Información General -->
            <RowDefinition Height="Auto"/>  <!-- Separador -->
            <RowDefinition Height="Auto"/>  <!-- OnDemand Triggers -->
            <RowDefinition Height="Auto"/>  <!-- Separador -->
            <RowDefinition Height="*"/>     <!-- Servicios -->
        </Grid.RowDefinitions>

        <!-- ═══ Sección: Información General ═══ -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Información General" Style="{StaticResource SectionHeader}"/>

            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Estado:" Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="1" Text="{Binding EstadoSistema}" Style="{StaticResource FieldValue}"/>
            </Grid>

            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Versión:" Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="1" Text="{Binding VersionApp}" Style="{StaticResource FieldValue}"/>
            </Grid>

            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Cola activa:" Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="1" Text="{Binding ColaActiva}" Style="{StaticResource FieldValue}" TextWrapping="Wrap"/>
            </Grid>

            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Configuración:" Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="1" Text="{Binding ConfigActiva}" Style="{StaticResource FieldValue}"/>
            </Grid>
        </StackPanel>

        <!-- Separador -->
        <Separator Grid.Row="1" Style="{StaticResource SectionSeparator}"/>

        <!-- ═══ Sección: On Demand Triggers (primero) ═══ -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Acciones A Demanda" Style="{StaticResource SectionHeader}"/>

            <!-- Mensaje cuando no hay triggers -->
            <TextBlock x:Name="NoTriggersMessage"
                       Text="No hay acciones disponibles."
                       Style="{StaticResource FieldValue}"
                       Foreground="#888888"
                       FontStyle="Italic"
                       Visibility="Collapsed"
                       Margin="0,4"/>

            <ItemsControl x:Name="TriggersListControl" ItemsSource="{Binding TriggersOnDemand}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Label}" Style="{StaticResource FieldValue}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="Ejecutar"
                                    Style="{StaticResource ActionButton}"
                                    IsEnabled="{Binding IsActionEnabled}"
                                    Click="TriggerExecute_Click"
                                    Tag="{Binding}"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Separador -->
        <Separator Grid.Row="3" Style="{StaticResource SectionSeparator}"/>

        <!-- ═══ Sección: Estado de Servicios (con ícono pequeño) ═══ -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="Servicios" Style="{StaticResource SectionHeader}"/>

            <ItemsControl ItemsSource="{Binding Servicios}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding DisplayName}" Style="{StaticResource FieldValue}"/>
                            <TextBlock Grid.Column="1" Text="{Binding State}" Style="{StaticResource FieldLabel}" FontSize="11"/>
                            <Button Grid.Column="2"
                                    Content="↻"
                                    Style="{StaticResource IconButton}"
                                    ToolTip="{Binding ActionLabel}"
                                    IsEnabled="{Binding IsActionEnabled}"
                                    Click="ServiceAction_Click"
                                    Tag="{Binding}"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</Window>
