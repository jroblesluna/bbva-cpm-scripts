<Window x:Class="AlwaysPrintTray.Forms.StatusForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AlwaysPrint — Estado del Sistema"
        Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5"
        DataContext="{Binding RelativeSource={RelativeSource Self}}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <StackPanel Margin="16">
        <!-- ═══ Información General ═══ -->
        <TextBlock x:Name="HeaderGeneral" FontFamily="Segoe UI Semibold" FontSize="13" Foreground="#0066CC" Margin="0,6,0,6"/>

        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock x:Name="LblStateText" Grid.Column="0" FontSize="12" Foreground="#555555"/>
            <TextBlock x:Name="ValState" Grid.Column="1" FontSize="12" Foreground="#1E1E1E"/>
        </Grid>
        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock x:Name="LblVersionText" Grid.Column="0" FontSize="12" Foreground="#555555"/>
            <TextBlock x:Name="ValVersion" Grid.Column="1" FontSize="12" Foreground="#1E1E1E"/>
        </Grid>
        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock x:Name="LblQueueText" Grid.Column="0" FontSize="12" Foreground="#555555"/>
            <TextBlock x:Name="ValQueue" Grid.Column="1" FontSize="12" Foreground="#1E1E1E" TextWrapping="Wrap"/>
        </Grid>
        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock x:Name="LblConfigText" Grid.Column="0" FontSize="12" Foreground="#555555"/>
            <TextBlock x:Name="ValConfig" Grid.Column="1" FontSize="12" Foreground="#1E1E1E"/>
        </Grid>

        <Separator Margin="0,8,0,4" Background="#DDDDDD"/>

        <!-- ═══ On Demand Triggers ═══ -->
        <TextBlock x:Name="HeaderOnDemand" FontFamily="Segoe UI Semibold" FontSize="13" Foreground="#0066CC" Margin="0,6,0,6"/>
        <TextBlock x:Name="NoTriggersMessage" FontSize="12" Foreground="#888888" FontStyle="Italic" Visibility="Collapsed" Margin="0,4"/>

        <ItemsControl x:Name="TriggersListControl" ItemsSource="{Binding TriggersOnDemand}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="12" Foreground="#1E1E1E" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="{Binding DataContext.LblExecute, RelativeSource={RelativeSource AncestorType=Window}}"
                                Padding="10,4" Background="#FFFFFF" BorderBrush="#CCCCCC" Cursor="Hand" MinWidth="68"
                                IsEnabled="{Binding IsActionEnabled}" Click="TriggerExecute_Click" Tag="{Binding}"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Separator Margin="0,8,0,4" Background="#DDDDDD"/>

        <!-- ═══ Servicios ═══ -->
        <TextBlock x:Name="HeaderServices" FontFamily="Segoe UI Semibold" FontSize="13" Foreground="#0066CC" Margin="0,6,0,6"/>

        <ItemsControl ItemsSource="{Binding Servicios}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding DisplayName}" FontSize="12" Foreground="#1E1E1E" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="1" Text="{Binding State}" FontSize="11" Foreground="#228B22" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Content="▶" FontSize="14" Padding="4,2" Width="28" Height="28"
                                Background="Transparent" BorderBrush="Transparent" Cursor="Hand"
                                ToolTip="{Binding DataContext.LblStartService, RelativeSource={RelativeSource AncestorType=Window}}"
                                IsEnabled="{Binding IsActionEnabled}"
                                Visibility="{Binding IsActionVisible, Converter={StaticResource BoolToVisibility}}"
                                Click="ServiceAction_Click" Tag="{Binding}"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Botón Cerrar -->
        <Button x:Name="BtnClose" HorizontalAlignment="Right" Margin="0,12,0,0"
                Padding="10,4" Background="#FFFFFF" BorderBrush="#CCCCCC" Cursor="Hand" MinWidth="68"
                IsCancel="True" Click="CloseButton_Click"/>
    </StackPanel>
</Window>
