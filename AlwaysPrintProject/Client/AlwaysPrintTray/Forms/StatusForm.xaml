<Window x:Class="AlwaysPrintTray.Forms.StatusForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AlwaysPrint — Estado del Sistema"
        Width="480" Height="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5"
        Foreground="#1E1E1E"
        DataContext="{Binding RelativeSource={RelativeSource Self}}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#1E1E1E"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#0066CC"/>
            <Setter Property="Margin" Value="0,10,0,6"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="68"/>
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI Symbol"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="200"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
        </Style>

        <Style x:Key="SectionSeparator" TargetType="Separator">
            <Setter Property="Margin" Value="0,6,0,2"/>
            <Setter Property="Background" Value="#DDDDDD"/>
        </Style>

        <!-- Estilo para estado del servicio con color -->
        <Style x:Key="ServiceState" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Información General -->
            <RowDefinition Height="Auto"/>  <!-- Separador -->
            <RowDefinition Height="Auto"/>  <!-- OnDemand Triggers -->
            <RowDefinition Height="Auto"/>  <!-- Separador -->
            <RowDefinition Height="Auto"/>  <!-- Servicios -->
        </Grid.RowDefinitions>

        <!-- ═══ Sección: Información General ═══ -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Información General" Style="{StaticResource SectionHeader}"/>

            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Estado:" Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="1" Text="{Binding EstadoSistema}" Style="{StaticResource FieldValue}"/>
            </Grid>

            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Versión:" Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="1" Text="{Binding VersionApp}" Style="{StaticResource FieldValue}"/>
            </Grid>

            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Cola activa:" Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="1" Text="{Binding ColaActiva}" Style="{StaticResource FieldValue}" TextWrapping="Wrap"/>
            </Grid>

            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Configuración:" Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="1" Text="{Binding ConfigActiva}" Style="{StaticResource FieldValue}"/>
            </Grid>
        </StackPanel>

        <!-- Separador -->
        <Separator Grid.Row="1" Style="{StaticResource SectionSeparator}"/>

        <!-- ═══ Sección: On Demand Triggers ═══ -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Acciones A Demanda" Style="{StaticResource SectionHeader}"/>

            <TextBlock x:Name="NoTriggersMessage"
                       Text="No hay acciones disponibles."
                       Style="{StaticResource FieldValue}"
                       Foreground="#888888"
                       FontStyle="Italic"
                       Visibility="Collapsed"
                       Margin="0,4"/>

            <ItemsControl x:Name="TriggersListControl" ItemsSource="{Binding TriggersOnDemand}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Label}" Style="{StaticResource FieldValue}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="Ejecutar"
                                    Style="{StaticResource ActionButton}"
                                    IsEnabled="{Binding IsActionEnabled}"
                                    Click="TriggerExecute_Click"
                                    Tag="{Binding}"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Separador -->
        <Separator Grid.Row="3" Style="{StaticResource SectionSeparator}"/>

        <!-- ═══ Sección: Servicios ═══ -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="Servicios" Style="{StaticResource SectionHeader}"/>

            <ItemsControl ItemsSource="{Binding Servicios}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding DisplayName}" Style="{StaticResource FieldValue}"/>
                            <TextBlock Grid.Column="1" Text="{Binding State}" Style="{StaticResource ServiceState}"
                                       Foreground="#228B22"/>
                            <Button Grid.Column="2"
                                    Content="▶"
                                    Style="{StaticResource IconButton}"
                                    ToolTip="Iniciar servicio"
                                    IsEnabled="{Binding IsActionEnabled}"
                                    Visibility="{Binding IsActionVisible, Converter={StaticResource BoolToVisibility}}"
                                    Click="ServiceAction_Click"
                                    Tag="{Binding}"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Botón Cerrar -->
        <Button Grid.Row="4" Content="Cerrar" Style="{StaticResource ActionButton}"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,12,0,0" IsCancel="True"
                Click="CloseButton_Click"/>
    </Grid>
</Window>
